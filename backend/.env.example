# ---- App ----
APP_ENV=development                 # development | production
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins for the future frontend.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- LLM provider (free options) ----
# Provider is selected here; no code change needed to switch.
#   groq          -> free cloud, fast (needs GROQ_API_KEY)
#   google_genai  -> free tier  (needs GOOGLE_API_KEY)
#   ollama        -> fully local & free (no key; run `ollama serve`)
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile   # gemini: gemini-2.0-flash | ollama: llama3.1
LLM_TEMPERATURE=0.7
LLM_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=3

GROQ_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Optional LangSmith tracing (leave blank to disable)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=

# ---- Datastores ----
# In docker-compose these default to the service hostnames.
DATABASE_URL=postgresql+asyncpg://engilearn:engilearn@localhost:5432/engilearn
REDIS_URL=redis://localhost:6379/0

# ---- Agent limits (cost & safety guards) ----
SYLLABUS_TURN_LIMIT=5
MAX_INPUT_CHARS=4000
MAX_HISTORY_MESSAGES=40

# ---- Rate limiting ----
RATE_LIMIT_CHAT=30/minute
RATE_LIMIT_SYLLABUS=10/minute
